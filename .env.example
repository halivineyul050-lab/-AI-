# 本地默认只监听 127.0.0.1:4173
HOST=127.0.0.1
PORT=4173
NODE_ENV=development

# 相对路径会按项目根目录解析
NIKE_DB_PATH=./data/nike-ai.db

# 生产环境必须设置为高强度随机值；留空时管理接口关闭
NIKE_ADMIN_TOKEN=
NIKE_ANALYTICS_SALT=
NIKE_ENABLE_TOKEN_ADMIN=false
NIKE_AUTO_SEED=true

# 多个来源用英文逗号分隔。同源部署不需要额外配置。
NIKE_ALLOWED_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
NIKE_TRUST_PROXY=false

# 自动采编：配置 OpenAI API Key 并设为 true 后启用
OPENAI_API_KEY=
NIKE_AUTO_NEWS=false
NIKE_NEWS_INTERVAL_MINUTES=360
NIKE_NEWS_AI_MODEL=gpt-4o-mini
NIKE_NEWS_FEEDS=https://openai.com/news/rss.xml,https://news.microsoft.com/source/topics/ai/feed/,https://blog.google/technology/ai/rss/
